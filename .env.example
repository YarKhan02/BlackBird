# BlackBird configuration example. Copy to .env and adjust.
# (.env is gitignored.)

# --- Core ---
ADDR=":8080"
DATABASE_URL="postgresql://blackbird:blackbird@localhost:5432/blackbird?sslmode=disable"
REDIS_URL="redis://localhost:6379"
RSA_PRIVATE_KEY_PATH="./keys/private.pem"
ENV="development"
JWT_ISSUER="auth.example.com"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="720h"

# --- Rate limiting ---
RATE_LIMIT_REQUESTS="100"
RATE_LIMIT_WINDOW="60s"

# --- Logging (Feature: structured logs -> Loki) ---
# Level: debug | info | warn | error
LOG_LEVEL="info"
# JSON logs are written to stdout and to this rotating file. Promtail tails it.
LOG_FILE="./logs/app.log"

# --- Sentry error tracking (Feature: Sentry) ---
# Leave SENTRY_DSN empty to disable error tracking entirely (no-op).
# Get the DSN from your sentry.io project settings.
SENTRY_DSN=""
# Defaults to ENV when unset.
SENTRY_ENVIRONMENT="development"
# 0.0 disables performance tracing; 0.0 - 1.0 enables sampling.
SENTRY_TRACES_SAMPLE_RATE="0.0"
